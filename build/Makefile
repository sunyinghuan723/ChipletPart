.PHONY : src/floorplan.s

# target to generate assembly for a file
src/floorplan.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/chipletPart.dir/build.make CMakeFiles/chipletPart.dir/src/floorplan.cpp.s
.PHONY : src/floorplan.cpp.s

src/pugixml.o: src/pugixml.cpp.o
.PHONY : src/pugixml.o

# target to build an object file
src/pugixml.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/pugixml.dir/build.make CMakeFiles/pugixml.dir/src/pugixml.cpp.o
.PHONY : src/pugixml.cpp.o

src/pugixml.i: src/pugixml.cpp.i
.PHONY : src/pugixml.i

