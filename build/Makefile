src/pugixml.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/pugixml.dir/build.make CMakeFiles/pugixml.dir/src/pugixml.cpp.s
.PHONY : src/pugixml.cpp.s

