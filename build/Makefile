src/pugixml.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/pugixml.dir/build.make CMakeFiles/pugixml.dir/src/pugixml.cpp.i
.PHONY : src/pugixml.cpp.i

